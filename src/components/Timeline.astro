---

import type { TimelineItem } from "../logic/structs.ts";

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
const sectionId = crypto.randomUUID();

---
<div class="timeline">
  {items.map((item, index) => (
    <div class="timeline-item" style={`--delay: ${index * 120}ms`}>
      <div class="timeline-dot"></div>

      <div class="timeline-content">
        <span class="timeline-date">{item.date}</span>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </div>
    </div>
  ))}
</div>

<style>
.timeline {
  position: relative;
  margin: 2rem 0;
  padding-bottom: 2rem;
  border-bottom: 3px solid var(--color-text-lowEmp);
  display: flex;
  width: max-content;
  --height: 4px;
}


.timeline-item {
  position: relative;
  margin-left: 2rem;
  opacity: 0;
}

.timeline-dot {
  position: absolute;
  bottom: calc(-2.7rem);
  left: 0.3rem;
  width: 14px;
  height: 14px;
  background: var(--background-color1);
  border-radius: 50%;
  border: 3px solid var(--color-text-lowEmp);
}


.timeline-content {
  background: var(--background-color1);
  border: 2px solid rgb(38, 38, 38);
  padding: 1rem;
  border-radius: 10px;
  width: 250px;
  height: 150px;
}

.timeline-date {
  font-size: 0.85rem;
  color: var(--color-text-lowEmp);
}


@media (max-width: 600px) {
  .timeline {
    flex-direction: column;
    border-bottom: none;
    border-left: 3px solid var(--color-text-lowEmp);

  }

  .timeline-item {
    position: relative;
    margin-left: 16px;
    margin-bottom: 16px;
  }

  .timeline-dot {
    position: absolute;
    left: -27px;
    top: 0.3rem;
    width: 14px;
    height: 14px;
    background: var(--background-color1);
    border-radius: 50%;
    border: 3px solid var(--color-text-lowEmp);
  }  
}


  /* Stagger animation */

  .timeline-item.show {
    animation: staggerAnimation 500ms ease-out forwards;
    animation-delay: var(--delay);

  }


</style>

<script defer define:vars={{ sectionId }}>
 const items = document.querySelectorAll(".timeline-item");

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("show");
        console.log("Show")
      } else {
        entry.target.classList.remove("show");
      }
    });
  });

  items.forEach((item) => observer.observe(item));
</script>