---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import Cards from '../components/Cards.astro';
import { CardData } from '../logic/structs';
import { CardDataItem } from '../logic/structs';
import Timeline from '../components/Timeline.astro';

import { base } from 'astro:config/client';
import Navigation from '../components/Navigation.astro';





function getCards(): CardData[] {
  return [
    { title: "Programmering", items: [
      { description: "Webutveckling i Javascript/Typescript" }, 
      { description: "SQL databaser i Rust" }, 
      { description: "Grafik och spel i C++ /Python" }, 
    ] },
    { title: "Digitalt skapande", items: [
      { description: "Grundläggande videoredigering, filming och fotografering" }, 
      { description: "3D modellering i Blender" }, 
      { description: "Infografik baserad på vektorgrafik" }, 
    ] },
    { title: "Naturvetenskap", items: [
      { description: "Läst fysik 1 och 2" }, 
      { description: "Läst matematik 5 och specialisering" }, 
    ] },
  ];
}



const eduTimelineItems = [
  {
    date: "2014-2017",
    title: "Söraskolan",
    description: "",
  },
  {
    date: "2017-2023",
    title: "Fredsborgskolan",
    description: "",
  },
  {
    date: "2023-2026",
    title: "Täby Enskilda Gymnasium",
    description: "Naturvetenskap",
  },
];



const workTimelineItems = [
  {
    date: "2025, 2026",
    title: "Österåkers kommun",
    description: "Finskt sommarläger + videoproduktion",
  },
];



---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/Portfolio/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Oscar Kristensson</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
  </head>
  <body>

  <Navigation />
    
  <Hero name="Oscar Kristensson" description="Glad och nyfiken student" img={base + "/oscar.png"} />

  <section class="bar centered">
    <h2>Färdigheter</h2>
    <Cards items={getCards()}/>
  </section>



  <section class="bar centered">
    <h2>Utbildning</h2>
    <Timeline items={eduTimelineItems}/>
  </section>


  <section class="bar centered">
    <h2>Jobb</h2>
    <Timeline items={workTimelineItems}/>
